PORT=3000

# Supabase is optional. If these are blank, Connect-ZA uses data/db.json.
# Preferred: direct Supabase Postgres connection. Replace [YOUR-PASSWORD].
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.cqwutrzqaijbgllrgsqu.supabase.co:5432/postgres

# Required for Supabase Storage uploads, and optional for Supabase REST database access.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STATE_TABLE=connect_za_state
SUPABASE_STATE_ID=production
SUPABASE_STORAGE_BUCKET=connect-za-media
SUPABASE_PRIVATE_STORAGE_BUCKET=connect-za-private
REQUIRE_SUPABASE_DATABASE=false

# Only set this to true for temporary local testing.
# On Render, leave it false/missing so bad Supabase config cannot silently lose registrations.
ALLOW_LOCAL_DB_FALLBACK=false

# Only set this to true for temporary local testing.
# On Render, leave it false/missing so uploads cannot be saved inline/base64.
ALLOW_INLINE_UPLOAD_FALLBACK=false

# Optional first admin account for a fresh production database.
# Set these in Render environment variables, not in GitHub.
ADMIN_EMAIL=admin@your-domain.co.za
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=Connect-ZA Admin
ADMIN_PHONE=+27000000000

# Yoco checkout. Add these on Render, not in GitHub.
YOCO_SECRET_KEY=your-yoco-secret-key
YOCO_WEBHOOK_SECRET=your-yoco-webhook-secret
YOCO_CURRENCY=ZAR
